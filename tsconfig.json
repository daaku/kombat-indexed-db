{
  "compilerOptions": {
    "declaration": true,
    "lib": ["ES2024", "DOM"],
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strictBindCallApply": true,
    "target": "esnext"
  }
}
